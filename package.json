{
  "name": "automation-framework",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",

  "scripts": {

  "clean":
    "rimraf allure-results allure-report playwright-report test-results",

  "test":
    "npm run clean && playwright test",

  "test:ui":
    "npm run clean && playwright test --project=chromium",

  "test:api":
    "npm run clean && playwright test --project=api",

  "test:smoke":
    "npm run clean && playwright test --grep @smoke",

  "test:regression":
    "npm run clean && playwright test --grep @regression",

  "test:sanity":
    "npm run clean && playwright test --grep @sanity",

  "test:e2e":
    "npm run clean && playwright test --grep @e2e",

  "test:ci":
    "playwright test",

  "allure:generate":
    "allure generate allure-results --clean",

  "allure:open":
    "allure open"
},

  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",

  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "allure-commandline": "^2.40.0",
    "allure-playwright": "^3.7.2",
    "rimraf": "^6.1.3"
  },

  "dependencies": {
    "dotenv": "^17.4.2"
  }
}